# Скопируйте этот файл в .env и заполните реальными значениями.
# .env в git не попадает (см. .gitignore), .env.example — наоборот,
# трекается, чтобы любой склонировавший репозиторий знал, что заполнять.

# Токен T-Invest API (создаётся в приложении/личном кабинете Т-Инвестиций,
# раздел "Настройки -> Токены для торговли API")
TINVEST_TOKEN=

# ID Google Таблицы (из её URL: docs.google.com/spreadsheets/d/<ЭТОТ_ID>/edit)
GOOGLE_SPREADSHEET_ID=

# Путь к JSON-файлу service account Google Cloud (см. README, раздел
# "Настройка Google Sheets"). По умолчанию ищется credentials.json
# в корне проекта.
GOOGLE_SERVICE_ACCOUNT_FILE=credentials.json

# Дата, с которой выгружать операции при первом запуске (без --from-last).
# Формат: YYYY-MM-DD или полный ISO datetime.
DEFAULT_FROM_DATE=2019-01-01T00:00:00Z

# Проверка SSL-сертификата API Т-Инвестиций.
# true (по умолчанию)  -- проверять (используется ca_bundle.pem, если он
#                          существует в корне проекта, либо системное
#                          хранилище ОС)
# false                -- отключить проверку полностью (не рекомендуется,
#                          только для диагностики)
TINVEST_VERIFY_SSL=true
